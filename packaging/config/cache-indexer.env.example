# BSDM-Proxy cache-indexer configuration
# Copy to /etc/bsdm-proxy/cache-indexer.env and adjust values.

KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC=cache-events
KAFKA_GROUP_ID=cache-indexer-group

CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=bsdm
CLICKHOUSE_TABLE=http_cache
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

METRICS_PORT=8080
# SEARCH_API_ENABLED=true
# SEARCH_API_TOKEN=
# SEARCH_API_MAX_LIMIT=10000
# SEARCH_API_DEFAULT_DAYS=30

# Logging — see docs/logging.md
RUST_LOG=info,cache_indexer=info
RUST_BACKTRACE=0
