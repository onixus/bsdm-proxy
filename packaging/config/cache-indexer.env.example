# BSDM-Proxy cache-indexer configuration
# Copy to /etc/bsdm-proxy/cache-indexer.env and adjust values.

KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC=cache-events
KAFKA_GROUP_ID=cache-indexer-group

OPENSEARCH_URL=http://127.0.0.1:9200
OPENSEARCH_INDEX=http-cache
# OPENSEARCH_ISM_ENABLED=true
# OPENSEARCH_ISM_POLICY_ID=bsdm-http-cache-policy
# OPENSEARCH_ISM_HOT_DAYS=14
# OPENSEARCH_ISM_DELETE_DAYS=42
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
OPENSEARCH_SSL_VERIFY=true

# Logging — see docs/logging.md
RUST_LOG=info,cache_indexer=info
RUST_BACKTRACE=0

# ClickHouse backend (ADR 0002)
# INDEXER_BACKEND=opensearch
# INDEXER_BACKEND=clickhouse
# CLICKHOUSE_URL=http://127.0.0.1:8123
# CLICKHOUSE_DATABASE=bsdm
# CLICKHOUSE_TABLE=http_cache
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
