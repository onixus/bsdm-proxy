# BSDM-Proxy configuration
# Copy to /etc/bsdm-proxy/bsdm-proxy.env and adjust values.

HTTP_PORT=1488
METRICS_PORT=9090

# MITM (requires /certs/ca.key and /certs/ca.crt)
MITM_ENABLED=true

# Cache
CACHE_CAPACITY=10000
CACHE_TTL_SECONDS=3600
MAX_CACHE_BODY_SIZE=10485760

# Kafka (optional — cache events)
# KAFKA_BROKERS=127.0.0.1:9092

# Graceful shutdown
SHUTDOWN_TIMEOUT_SECONDS=30

# Proxy authentication
AUTH_ENABLED=false
# AUTH_BACKEND=ldap
# AUTH_REALM=BSDM-Proxy
# LDAP_SERVERS=ldap://127.0.0.1:389
# LDAP_BASE_DN=dc=example,dc=com

# ACL / categorization
ACL_ENABLED=false
ACL_DEFAULT_ACTION=allow
ACL_RULES_PATH=/etc/bsdm-proxy/acl-rules.json
ACL_AUTO_RELOAD=false
# ACL_RELOAD_INTERVAL=60

CATEGORIZATION_ENABLED=false
# CUSTOM_DB_PATH=/etc/bsdm-proxy/custom-categories.json

# Upstream TLS (for self-signed upstream CA in tests/lab)
# UPSTREAM_CA_CERT=/etc/bsdm-proxy/upstream-ca.crt

RUST_LOG=info,bsdm_proxy=info
RUST_BACKTRACE=0
