          "rawSql": "SELECT\n  domain,\n  count() AS requests,\n  uniqExact(client_ip) AS clients,\n  length(domain) AS domain_len,\n  length(splitByChar('.', domain)[1]) AS label_len\nFROM bsdm.http_cache\nWHERE $__timeFilter(ts)\n  AND length(domain) >= 16\nGROUP BY domain\nHAVING requests >= 5\nORDER BY requests DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Long-domain candidates (Shannon post-filter in alert-worker)",
